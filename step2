// حفظ
function saveGPA(name, gpa) {
    let history = JSON.parse(localStorage.getItem("gpaHistory")) || [];
    history.push({ name, gpa });
    localStorage.setItem("gpaHistory", JSON.stringify(history));
}

// عرض
function loadHistory() {
    let history = JSON.parse(localStorage.getItem("gpaHistory")) || [];
    let output = "";

    history.forEach(item => {
        output += <li>${item.name} : ${item.gpa}</li>;
    });

    document.getElementById("history").innerHTML = output;
}

// إرسال للسيرفر
function sendToServer(name, gpa) {
    fetch("save.php", {
        method: "POST",
        headers: {
            "Content-Type": "application/x-www-form-urlencoded"
        },
        body: name=${name}&gpa=${gpa}
    });
}

// Progress Bar
function updateBar(gpa) {
    let percent = (gpa / 4) * 100;
    let bar = document.getElementById("bar");

    bar.style.width = percent + "%";
    bar.innerText = gpa;

    if (gpa >= 3.7) bar.className = "progress-bar bg-success";
    else if (gpa >= 3.0) bar.className = "progress-bar bg-primary";
    else if (gpa >= 2.0) bar.className = "progress-bar bg-warning";
    else bar.className = "progress-bar bg-danger";
}

// حساب
function calculateGPA() {
    let name = document.getElementById("name").value;

    if (name === "") {
        alert("Enter your name");
        return;
    }

    let gpa = (Math.random() * 4).toFixed(2);

    document.getElementById("result").innerText = "GPA: " + gpa;

    saveGPA(name, gpa);
    loadHistory();
    sendToServer(name, gpa);
    updateBar(gpa);
}

// تحميل
window.onload = loadHistory
}
